# ─── Cloud (relay-server.js) ────────────────────────────────
# Railway dashboard-da bu env vars əlavə edin:

# Agent-in qoşulması üçün secret key (istənilən random string)
AGENT_SECRET=bot-secret-2024

# PORT — Railway avtomatik təyin edir, əl ilə dəyişməyin
PORT=3000

# ─── Lokal Agent (agent.js) ──────────────────────────────────
# Relay server URL (Railway-dən alınan URL)
RELAY_URL=scrape-production-5d7a.up.railway.app

# Yuxarıdakı ilə eyni olmalıdır
AGENT_SECRET=bot-secret-2024

# Agent-in adı (istənilən — log-larda görünür)
AGENT_LABEL=Ofis-PC
