# ═══════════════════════════════════════════════════════════════
# RELAY SERVER (relay-server.js) — Railway dashboard-da təyin et
# ═══════════════════════════════════════════════════════════════

# Agent-in qoşulması üçün secret key (lokal .env ilə eyni olmalıdır)
AGENT_SECRET=bot-secret-2024

# Puppeteer Chromium-u yükləməsin (Railway build-də lazımsızdır)
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_SKIP_DOWNLOAD=true

# PORT — Railway avtomatik təyin edir, əl ilə dəyişməyin


# ═══════════════════════════════════════════════════════════════
# LOCAL AGENT (agent.js) — istifadəçinin kompüterindəki .env fayl
# ═══════════════════════════════════════════════════════════════

# Railway-dəki relay server URL (mütləq wss:// ilə başlamalıdır)
RELAY_URL=wss://scrape-production-5d7a.up.railway.app

# Yuxarıdakı AGENT_SECRET ilə eyni olmalıdır
AGENT_SECRET=bot-secret-2024

# Agent-in adı — Railway log-larında görünür (istənilən ad)
AGENT_LABEL=Ofis-PC

# Edge debug portları — başqa proqram istifadə edirsə dəyişdirin
# E-Social üçün (default: 9222)
ESOCIAL_DEBUG_PORT=9222
# IMEI üçün (default: 9223)
IMEI_DEBUG_PORT=9223
